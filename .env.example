# ---- Copy to .env and fill in ------------------------------------------------
# Gateway admin key (choose your own random string)
LITELLM_MASTER_KEY=sk-local-master

# Frontier provider keys (any subset; leave blank to disable that provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Local inference endpoints
# In-compose Ollama (default):        http://ollama:11434
# Host-native Ollama (macOS/Windows): http://host.docker.internal:11434
OLLAMA_API_BASE=http://ollama:11434
VLLM_API_BASE=http://vllm:8000/v1

# vLLM model (only with --profile gpu); AWQ INT4 of the 27B dense fits in ~24 GB VRAM
VLLM_MODEL=QuantTrio/Qwen3.6-27B-AWQ
VLLM_MAX_LEN=16384
HF_TOKEN=

# Grafana admin password
GRAFANA_PASSWORD=admin
