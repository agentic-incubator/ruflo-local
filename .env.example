# ---- Copy to .env and fill in ------------------------------------------------
# Gateway admin key (choose your own random string)
LITELLM_MASTER_KEY=sk-local-master

# Frontier provider keys (any subset; leave blank to disable that provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Local inference endpoints
# In-compose Ollama (default):        http://ollama:11434
# Host-native Ollama (macOS/Windows): http://host.docker.internal:11434
OLLAMA_API_BASE=http://ollama:11434
VLLM_API_BASE=http://vllm:8000/v1

# vLLM model (only with --profile gpu); AWQ INT4 of the 27B dense fits in ~24 GB VRAM
VLLM_MODEL=QuantTrio/Qwen3.6-27B-AWQ
VLLM_MAX_LEN=16384
HF_TOKEN=

# Grafana admin password
GRAFANA_PASSWORD=admin

# =============================================================================
# ruflo router env (client-side) — §1 stronger routing signal + §2 escalation.
# NOTE: these are consumed by ruflo/claude-flow in YOUR shell, NOT by
# docker-compose. Full guidance: docs/guide/reference/tiers-and-routing.md
# (§1/§2). Values below are ILLUSTRATIVE starting points — verify the flags
# against your ruflo build and re-tune against your own metrics.
# =============================================================================

# --- §1: turn on the shipped neural router (else the lexical/bandit path) ---
CLAUDE_FLOW_ROUTER_NEURAL=1
CLAUDE_FLOW_ROUTER_NEURAL_WEIGHT=0.7            # blend weight neural <-> bandit
CLAUDE_FLOW_ROUTER_KNN_K=16                     # k for the k-NN backend
CLAUDE_FLOW_ROUTER_QUALITY_BAR=0.8              # min predicted quality before down-tiering
CLAUDE_FLOW_ROUTER_COST_CEILING_USD_PER_MTOK=20 # $20 excludes Sonnet+Opus-class; $50 excludes only Opus
CLAUDE_FLOW_ROUTER_EMBED_CACHE_SIZE=4096        # HNSW semantic route cache — near-dupes skip re-scoring

# --- §2: uncertainty-forced up-tier (quality-floor-beats-quota escalation) ---
CLAUDE_FLOW_ROUTER_ENSEMBLE_UNCERTAINTY_THRESHOLD=0.35

# --- ruflo -> gateway wiring (already covered in tiers-and-routing.md) --------
CLAUDE_FLOW_ROUTER_OPENROUTER_ALTS=./ruflo-tiers.json   # ships in this kit
# The per-agent-type tier FLOOR is reference policy, not an env var — see
# router-policy.example.json (escalation.tier_floor_by_agent_type).

# =============================================================================
# COMPOSE_PROFILES — the GATEWAY SELECTOR
# -----------------------------------------------------------------------------
# Purpose: picks which OpenAI-compatible gateway serves the :4000 seam. The three
# gateways are MUTUALLY EXCLUSIVE (each binds host :4000), so name EXACTLY ONE.
# Docker Compose reads this from .env; it decides which profiled services start.
#
# What it does:
#   docker compose up -d   → starts the gateway named here (+ shared infra:
#                            ollama, prometheus, grafana, otel-collector, which
#                            are unprofiled and always run).
#
# Viable options (choose ONE gateway):
#   litellm   → DEFAULT. Python + Postgres reference gateway. Richest surface:
#               per-deployment budgets, fallbacks, RouteLLM 90/10 dial, virtual keys.
#   bifrost   → Rust, µs-class overhead, native OTel, no Python/Postgres footprint.
#               Uses bifrost-config.json. (Experimental — see gateway-variants.md.)
#   helicone  → (added in the Helicone phase) Rust, native OTel + rich budgets/caching.
#
# Rules:
#   • EMPTY value  → NO gateway starts (:4000 is dead).
#   • TWO gateways (e.g. "litellm,bifrost") → both start → both claim :4000 → `up` FAILS.
#   • Combine ONLY with overlays, never another gateway:
#       COMPOSE_PROFILES=litellm,gpu      (adds vLLM)
#       COMPOSE_PROFILES=litellm,router   (adds RouteLLM)
#
# Override per-run without editing this file:
#       COMPOSE_PROFILES=bifrost docker compose up -d --remove-orphans
#
# Docs: docs/guide/reference/gateway-variants.md
# =============================================================================
COMPOSE_PROFILES=litellm
