{
  "_meta": {
    "purpose": "Bifrost gateway config mirroring this kit's four tier aliases, for the `bifrost` compose profile (COMPOSE_PROFILES=bifrost). Bifrost is the Go, µs-class, native-OTel alternative to the default LiteLLM gateway — see docs/guide/reference/gateway-variants.md.",
    "note": "EXPERIMENTAL TEMPLATE — Bifrost's config schema evolves; verify these keys against the pinned image (maximhq/bifrost:v1.5.2) before relying on it. What MUST hold regardless of schema: the four aliases exist, tier-private has an EMPTY fallback list (the privacy pin — it can never leave the box), and tier-frontier carries the daily budget. GENERATED FILE — do not edit bifrost-config.json by hand; edit config/templates/bifrost-config.json.tmpl + config/model-sets.json and run `make render` (the local model tags are filled per-hardware at render time).",
    "schema_version": 1
  },

  "providers": {
    "_ollama_note": "base_url is the IN-CONTAINER ollama URL; unlike LiteLLM this is not read from OLLAMA_API_BASE. Host-native Ollama (macOS/Windows, --scale ollama=0): change this to http://host.docker.internal:11434/v1 — see gateway-variants.md. The local model tags below are selected per-hardware by scripts/render-configs.mjs (Apple-Silicon MLX builds vs plain).",
    "ollama":    { "type": "openai_compatible", "base_url": "http://ollama:11434/v1" },
    "anthropic": { "type": "anthropic", "api_key": "env.ANTHROPIC_API_KEY" },
    "openai":    { "type": "openai",    "api_key": "env.OPENAI_API_KEY" },
    "gemini":    { "type": "gemini",    "api_key": "env.GEMINI_API_KEY" }
  },

  "models": {
    "tier-fast":  { "provider": "ollama", "model": "{{TIER_FAST_MODEL}}", "locality": "local" },
    "tier-heavy": { "provider": "ollama", "model": "{{TIER_HEAVY_MODEL}}", "locality": "local" },
    "tier-frontier": {
      "provider": "anthropic",
      "model": "claude-opus-4-8",
      "locality": "cloud",
      "fallbacks": ["openai/gpt-4.1", "gemini/gemini-2.5-pro"],
      "budget": { "max_usd_per_day": 7.0, "rpm": 6, "tpm": 60000 }
    },
    "tier-private": {
      "provider": "ollama",
      "model": "{{TIER_PRIVATE_MODEL}}",
      "locality": "local",
      "fallbacks": []
    }
  },

  "telemetry": {
    "prometheus": true,
    "otel_endpoint": "http://otel-collector:4318"
  }
}
