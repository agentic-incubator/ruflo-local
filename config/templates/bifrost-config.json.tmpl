// Bifrost gateway config mirroring this kit's four tier aliases, for the `bifrost`
// compose profile (COMPOSE_PROFILES=bifrost) — the Go, µs-class, native-OTel
// alternative to the default LiteLLM gateway. See docs/guide/reference/gateway-variants.md.
//
// EXPERIMENTAL — verify against the pinned image (maximhq/bifrost:v1.5.2). Schema
// corrected 2026-07-07: the prior shape (providers.{type,base_url,api_key}, a
// top-level `models` map) was invalid against v1.5.2's REAL schema (confirmed live —
// its own validator rejects it). Real Bifrost provider config is keys[]-based: each
// key has name/value/a `models` ALLOW-LIST (the alias names this key may serve) plus
// provider-specific *_key_config, and a client-facing alias (e.g. "tier-fast") maps
// to the real model id via keys[].aliases. Fallback is PROVIDER-scoped
// (governance.routing_rules[].fallbacks lists provider names to retry) — there is no
// direct equivalent of LiteLLM's per-alias tier-fast->tier-heavy chain; see the
// governance block below for what this DOES and does not cover.
//
// This file has NO native JSON comments — whole-line `//` comments here are stripped
// by scripts/render-configs.mjs before Bifrost ever sees the output (its schema is
// additionalProperties:false almost everywhere, so a "_meta"/"_note" documentation
// key — this repo's convention elsewhere — fails validation outright).
//
// GENERATED FILE — do not edit bifrost-config.json by hand; edit this .tmpl +
// config/model-sets.json and run `make render` (model tags filled per-hardware).
{
  "$schema": "https://www.getbifrost.ai/schema",

  "providers": {
    // url is the IN-CONTAINER ollama URL; unlike LiteLLM this is not read from
    // OLLAMA_API_BASE. Host-native Ollama (macOS/Windows, --scale ollama=0): change
    // {{OLLAMA_BASE_URL_BARE}} below to http://host.docker.internal:11434 — see
    // gateway-variants.md. Model tags are selected per-hardware by
    // scripts/render-configs.mjs; the "ci" variant points this at fake-upstream
    // (docker-compose.ci.yml) instead of real Ollama. One key per tier alias (not one
    // shared key) so each alias maps to its own real model tag via `aliases`.
    "ollama": {
      "keys": [
        {
          "name": "tier-fast",
          "value": "",
          "models": ["tier-fast"],
          "weight": 1.0,
          "aliases": { "tier-fast": "{{TIER_FAST_MODEL}}" },
          "ollama_key_config": { "url": "{{OLLAMA_BASE_URL_BARE}}" }
        },
        {
          "name": "tier-heavy",
          "value": "",
          "models": ["tier-heavy"],
          "weight": 1.0,
          "aliases": { "tier-heavy": "{{TIER_HEAVY_MODEL}}" },
          "ollama_key_config": { "url": "{{OLLAMA_BASE_URL_BARE}}" }
        },
        {
          "name": "tier-private",
          "value": "",
          "models": ["tier-private"],
          "weight": 1.0,
          "aliases": { "tier-private": "{{TIER_PRIVATE_MODEL}}" },
          "ollama_key_config": { "url": "{{OLLAMA_BASE_URL_BARE}}" }
        }
      ]
    },
    "anthropic": {
      "keys": [
        {
          "name": "tier-frontier-anthropic",
          "value": "env.ANTHROPIC_API_KEY",
          "models": ["tier-frontier"],
          "weight": 1.0,
          "aliases": { "tier-frontier": "claude-opus-4-8" }
        }
      ]
    },
    "openai": {
      "keys": [
        {
          "name": "tier-frontier-openai",
          "value": "env.OPENAI_API_KEY",
          "models": ["tier-frontier"],
          "weight": 1.0,
          "aliases": { "tier-frontier": "gpt-4.1" }
        }
      ]
    },
    "gemini": {
      "keys": [
        {
          "name": "tier-frontier-gemini",
          "value": "env.GEMINI_API_KEY",
          "models": ["tier-frontier"],
          "weight": 1.0,
          "aliases": { "tier-frontier": "gemini-2.5-pro" }
        }
      ]
    }
  },

  // KNOWN GAP: this rule covers tier-frontier's own cross-provider fallback
  // (anthropic -> openai -> gemini). It does NOT reproduce LiteLLM's tier-fast ->
  // tier-heavy -> tier-frontier chain — Bifrost's fallbacks are provider-scoped, not
  // alias-scoped, so there is no clean equivalent yet. smoke-test.sh's fall-through
  // drill prints the served-by result for this variant rather than hard-asserting on
  // it, for exactly this reason.
  "governance": {
    "routing_rules": [
      {
        "id": "tier-frontier-provider-fallback",
        "name": "tier-frontier: anthropic primary, openai/gemini fallback",
        "enabled": true,
        "cel_expression": "model == 'tier-frontier'",
        "targets": [{ "provider": "anthropic", "weight": 1.0 }],
        "fallbacks": ["openai", "gemini"],
        "scope": "global",
        "priority": 0
      }
    ]
  }
}
